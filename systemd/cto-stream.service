[Unit]
Description=Encode the FIFO to Icecast
Requires=cto-fifo.service
After=cto-fifo.service cto-pipe-keeper.service
[Service]
EnvironmentFile=%h/.config/cto-stream/stream.env
ExecStart=/usr/bin/ffmpeg -hide_banner -loglevel warning -f s16le -ar 44100 -ac 2 -i %h/.local/share/go-librespot/audio.fifo -c:a libmp3lame -b:a 128k -content_type audio/mpeg -f mp3 icecast://source:${SRC}@127.0.0.1:8000/stream-${LIS}.mp3
Restart=always
RestartSec=3
[Install]
WantedBy=default.target
